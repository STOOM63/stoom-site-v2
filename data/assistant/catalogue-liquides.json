{
  "version": "2.0.0",
  "mise_a_jour": "2026-06-22",
  "nom": "Catalogue liquides — Assistant STOOM",
  "description": "Manifest central lu par le Worker STOOM. Les recettes restent dans les JSON existants de chaque gamme. Le Worker charge chaque produit réel et calcule un profil de conseil précis : familles, notes dominantes, fraîcheur, sucrosité, acidité et intensité.",
  "regles_assistant": {
    "recommandation": [
      "Proposer uniquement des recettes présentes dans les JSON source ci-dessous.",
      "Proposer au maximum trois liquides à la fois.",
      "Ne jamais annoncer un stock : indiquer que la disponibilité est à confirmer en boutique STOOM.",
      "En cas de demande « sans frais », exclure les recettes détectées comme fraîches ou très fraîches.",
      "Pour une alternative à un liquide cité, privilégier les recettes proches par notes dominantes et famille, sans prétendre à une copie exacte."
    ],
    "nicotine": [
      "Ne citer un format ou un taux de nicotine que lorsqu’il est présent dans la fiche produit source.",
      "Pour les grands formats à 0 mg, ne pas annoncer de dosage final sans connaître les boosters utilisés."
    ]
  },
